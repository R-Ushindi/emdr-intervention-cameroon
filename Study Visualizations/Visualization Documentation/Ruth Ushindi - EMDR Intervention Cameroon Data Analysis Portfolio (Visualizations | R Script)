  height = 6,
  dpi = 300
)

# =========================================================
# 9. FOREST PLOT OF EFFECT SIZES
# =========================================================

# Continuous outcomes
cohens_d_cont <- function(x, y) {

  n1 <- length(x)
  n2 <- length(y)

  m1 <- mean(x, na.rm = TRUE)
  m2 <- mean(y, na.rm = TRUE)

  sd1 <- sd(x, na.rm = TRUE)
  sd2 <- sd(y, na.rm = TRUE)

  pooled_sd <- sqrt(
    ((n1 - 1) * sd1^2 +
       (n2 - 1) * sd2^2) /
      (n1 + n2 - 2)
  )

  d <- (m2 - m1) / pooled_sd

  # Hedges correction
  J <- 1 - (3 / (4 * (n1 + n2 - 2) - 1))

  d_corrected <- d * J

  se <- sqrt(
    (n1 + n2) / (n1 * n2) +
      (d_corrected^2) /
      (2 * (n1 + n2))
  )

  c(
    d = d_corrected,
    lower = d_corrected - 1.96 * se,
    upper = d_corrected + 1.96 * se
  )
}

# Binary outcome approximation
cohens_d_binary <- function(ctrl_vec, trt_vec) {

  p1 <- mean(ctrl_vec, na.rm = TRUE)
  p2 <- mean(trt_vec, na.rm = TRUE)

  n1 <- sum(!is.na(ctrl_vec))
  n2 <- sum(!is.na(trt_vec))

  p_bar <- (p1 * n1 + p2 * n2) / (n1 + n2)

  h <- 2 * asin(sqrt(p2)) -
    2 * asin(sqrt(p1))

  d <- h / 1.65

  se <- sqrt(
    (p1 * (1 - p1) / n1) +
      (p2 * (1 - p2) / n2)
  ) / sqrt(p_bar * (1 - p_bar))

  c(
    d = d,
    lower = d - 1.96 * se,
    upper = d + 1.96 * se
  )
}

# Split data by group
ctrl <- df[df$Group == "Control", ]
trt  <- df[df$Group == "Treatment", ]

# Compute effect sizes
d_ptsd <- cohens_d_cont(
  ctrl$PTSDEndline,
  trt$PTSDEndline
)

d_dep <- cohens_d_cont(
  ctrl$DepressionEndline,
  trt$DepressionEndline
)

d_anx <- cohens_d_cont(
  ctrl$AnxietyEndline,
  trt$AnxietyEndline
)

ctrl_burn <- ifelse(
  ctrl$BurnoutBaseline == "At risk",
  1,
  0
)

trt_burn <- ifelse(
  trt$BurnoutBaseline == "At risk",
  1,
  0
)

d_burn <- cohens_d_binary(
  ctrl_burn,
  trt_burn
)

forest_data <- data.frame(
  Outcome = c(
    "PTSD",
    "Depression",
    "Anxiety",
    "Burnout"
  ),
  d = c(
    d_ptsd["d"],
    d_dep["d"],
    d_anx["d"],
    d_burn["d"]
  ),
  lower = c(
    d_ptsd["lower"],
    d_dep["lower"],
    d_anx["lower"],
    d_burn["lower"]
  ),
  upper = c(
    d_ptsd["upper"],
    d_dep["upper"],
    d_anx["upper"],
    d_burn["upper"]
  )
)

p6 <- ggplot(
  forest_data,
  aes(
    x = d,
    y = reorder(Outcome, d)
  )
) +
  geom_vline(
    xintercept = 0,
    linetype = "dashed"
  ) +
  geom_point(
    size = 3,
    color = "#0072B2"
  ) +
  geom_errorbarh(
    aes(
      xmin = lower,
      xmax = upper
    ),
    height = 0.2,
    linewidth = 0.8
  ) +
  labs(
    x = "Cohen's d (95% CI)",
    y = NULL,
    caption = "Positive effect sizes favor treatment."
  ) +
  theme_classic(base_size = 12)

ggsave(
  "outputs/Figure6_Forest.png",
  p6,
  width = 6,
  height = 4,
  dpi = 300
)

