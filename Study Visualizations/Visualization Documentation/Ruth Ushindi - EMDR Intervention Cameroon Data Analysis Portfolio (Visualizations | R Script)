  group_by(Group, Status) %>%
  summarise(
    n = n(),
    .groups = "drop"
  ) %>%
  group_by(Group) %>%
  mutate(
    percent = n / sum(n) * 100
  )

p4 <- ggplot(
  remission_df,
  aes(
    x = Group,
    y = percent,
    fill = Status
  )
) +
  geom_col(width = 0.7) +
  scale_fill_brewer(palette = "Set2") +
  labs(
    y = "Percentage (%)",
    caption = "Remission = PCL-5 < 33 at endline."
  ) +
  theme_classic(base_size = 12)

ggsave(
  "outputs/Figure4_Remission.png",
  p4,
  width = 5,
  height = 4,
  dpi = 300
)

