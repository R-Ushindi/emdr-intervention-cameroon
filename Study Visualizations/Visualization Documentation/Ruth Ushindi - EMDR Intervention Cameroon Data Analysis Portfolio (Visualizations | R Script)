# =========================================================
# 1. SETUP
# =========================================================

library(tidyverse)
library(ggpubr)
library(UpSetR)
library(viridis)

# Set working directories
root <- "Desktop/EMDR_for_PTSD_R_Visualizations"

figures_dir <- file.path(root, "outputs", "figures")

if (!dir.exists(figures_dir)) {
  dir.create(figures_dir, recursive = TRUE)
}

# =========================================================
# 2. LOAD DATA
# =========================================================

df <- read.csv("EMDR_for_PTSD.csv")

# =========================================================
# 3. DATA PREPARATION
# =========================================================

# Convert group variable to factor
df$Group <- factor(
  df$Group,
  levels = c("Control", "Treatment")
)

# Create participant index
df$id <- 1:nrow(df)

# Convert burnout status to binary
# 0 = No burnout
# 1 = At risk

df$BurnoutBinary <- ifelse(
  df$BurnoutBaseline == "At risk",
  1,
  0
)

# =========================================================
# 4. BASELINE PREVALENCE BAR CHART
# =========================================================

prev_df <- data.frame(
  Condition = c(
    "PTSD",
    "Depression",
    "Anxiety",
    "Burnout"
  ),
  prop = c(
    mean(df$PTSDstatusBaseline, na.rm = TRUE),
    mean(df$DepressionstatusBaseline, na.rm = TRUE),
    mean(df$AnxietystatusBaseline, na.rm = TRUE),
    mean(df$BurnoutBinary, na.rm = TRUE)
  )
)

n <- nrow(df)

prev_df <- prev_df %>%
  mutate(
    se = sqrt(prop * (1 - prop) / n),
    ci = 1.96 * se,
    percent = prop * 100
  )

p1 <- ggplot(
  prev_df,
  aes(
    x = reorder(Condition, percent),
    y = percent
  )
) +
  geom_col(
    fill = "steelblue",
    width = 0.7
  ) +
  geom_errorbar(
    aes(
      ymin = (prop - ci) * 100,
      ymax = (prop + ci) * 100
    ),
    width = 0.2
  ) +
  coord_flip() +
  labs(
    y = "Prevalence (%)",
    x = NULL,
    caption = "Error bars represent 95% confidence intervals. N = 134."
  ) +
  theme_classic(base_size = 12)

ggsave(
  "outputs/Figure1_Baseline.png",
  p1,
  width = 5,
  height = 4,
  dpi = 300
)

# =========================================================
# 5. GROUP × TIME LINE GRAPH
# =========================================================

pcl_long <- df %>%
  select(
    id,
    Group,
    PTSDBaseline,
    PTSDMidline,
    PTSDEndline
  ) %>%
  pivot_longer(
    cols = starts_with("PTS"),
    names_to = "Time",
    values_to = "PCL"
  ) %>%
  mutate(
    Time = factor(
      Time,
      levels = c(
        "PTSDBaseline",
        "PTSDMidline",
        "PTSDEndline"
      ),
      labels = c(
        "Baseline",
        "Midline",
        "Endline"
      )
    )
  )

summary_df <- pcl_long %>%
  group_by(Group, Time) %>%
  summarise(
    mean = mean(PCL, na.rm = TRUE),
    se = sd(PCL, na.rm = TRUE) / sqrt(n()),
    ci = 1.96 * se,
    .groups = "drop"
  )

p2 <- ggplot(
  summary_df,
  aes(
    x = Time,
    y = mean,
    color = Group,
    group = Group
  )
) +
  geom_line(linewidth = 1.2) +
  geom_point(size = 3) +
  geom_errorbar(
    aes(
      ymin = mean - ci,
      ymax = mean + ci
    ),
    width = 0.15,
    linewidth = 0.8
  ) +
  geom_hline(
    yintercept = 33,
    linetype = "dashed",
    color = "gray30"
  ) +
  annotate(
    "text",
    x = 2.8,
    y = 35,
    label = "Clinical cutoff (33)",
    size = 3,
    hjust = 0
  ) +
  annotate(
    "text",
    x = 2,
    y = 48,
    label = "η²p = .891, p < .001",
    size = 4,
    fontface = "italic"
  ) +
  scale_color_manual(
    values = c(
      "Control" = "#D55E00",
      "Treatment" = "#0072B2"
    )
  ) +
  labs(
    y = "Mean PCL-5 Score (±95% CI)",
    x = "Assessment Time Point",
    caption = "Error bars represent 95% confidence intervals. N = 134."
  ) +
  theme_classic(base_size = 12) +
  theme(
    legend.position = c(0.85, 0.85)
  )

ggsave(
  "outputs/Figure2_GroupTime.png",
  p2,
  width = 6,
  height = 4,
  dpi = 300
)

